OSS_SENTINEL_GITHUB_TOKEN=ghp_or_app_installation_token
OSS_SENTINEL_WEBHOOK_SECRET=change-me
OSS_SENTINEL_DRY_RUN=true
OSS_SENTINEL_HOST=127.0.0.1
OSS_SENTINEL_PORT=8080
OSS_SENTINEL_THREAT_MODEL=threat_model.json
OSS_SENTINEL_CONFIG=sentinel.yml

# Optional adapter for a deeper scanner. The command receives JSON on stdin
# and must return a ScanReport-compatible JSON document on stdout.
# OSS_SENTINEL_SECURITY_CMD=codex-security-scan --format json
OSS_SENTINEL_SECURITY_TIMEOUT=120

OSS_SENTINEL_APPROVE_LABEL=security/approved
OSS_SENTINEL_BLOCK_LABEL=security/blocked
OSS_SENTINEL_REVIEW_LABEL=security/review
OSS_SENTINEL_SUBMIT_REVIEWS=false
OSS_SENTINEL_COMMENT_ON_APPROVAL=false
